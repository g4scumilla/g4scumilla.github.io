<!DOCTYPE html>
<html>
<head>
  <title>Wallet Test</title>
</head>
<body>

<h2>Wallet API Test</h2>

<input id="person" placeholder="Person"><br><br>
<input id="type" placeholder="Type (Income/Expense)"><br><br>
<input id="category" placeholder="Category"><br><br>
<input id="amount" type="number" placeholder="Amount"><br><br>
<input id="note" placeholder="Note"><br><br>

<button onclick="sendData()">Send</button>

<script>
function sendData() {
  fetch("https://script.google.com/macros/s/AKfycbxkEeloWphhqH2t4O47VXyK6hzCvz-AC_l0EvhwX9HYs1P3xu6NrO8Wq7lSHnboOgZA/exec", {
    method: "POST",
    body: JSON.stringify({
      person: document.getElementById("person").value,
      type: document.getElementById("type").value,
      category: document.getElementById("category").value,
      amount: document.getElementById("amount").value,
      note: document.getElementById("note").value
    })
  })
  .then(res => res.text())
  .then(data => alert(data))
}
</script>

</body>
</html>